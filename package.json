{
  "name": "workflow",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/main.ts ./src/benchmark.ts ./src/integration-example.ts --outdir ./public/assets --target browser",
    "build:lib": "bun build ./src/index.ts --outdir ./dist --format esm --target browser",
    "build:pages": "bun run build && bun run scripts/build-pages.ts",
    "dev": "bun run build && bun run server.ts",
    "start": "bun run server.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
